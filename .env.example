# Copiez ce fichier en ".env" et remplissez vos vraies valeurs.
# Sans ces valeurs, chaque connecteur tourne en mode "mock" (donnees d'exemple)
# pour permettre de tester le serveur et le dashboard sans acces API.

# --- Serveur ---
PORT=3000
# Frequence de synchronisation (cron). Par defaut: toutes les 30 minutes.
SYNC_CRON=*/30 * * * *
# Timeout par requete HTTP individuelle vers Shopify/IO (ms). Evite qu'une
# connexion qui reste ouverte sans reponse ne bloque la sync indefiniment.
HTTP_TIMEOUT_MS=20000
# Garde-fou global par source: force un echec propre de la sync si elle
# n'a pas termine apres ce delai (ms), meme en cas de blocage imprevu.
SYNC_WATCHDOG_MS=120000

# --- Shopify ---
# Domaine de la boutique, ex: my-shop.myshopify.com
SHOPIFY_SHOP=
#
# Option A - App "legacy" (creee avant le Dev Dashboard, avant jan. 2026):
# token d'acces Admin API statique, fourni directement par Shopify.
SHOPIFY_ACCESS_TOKEN=
#
# Option B - App creee via le Dev Dashboard Shopify (depuis jan. 2026):
# ces apps n'ont plus de token statique, il faut passer par OAuth
# (client credentials grant). Laissez SHOPIFY_ACCESS_TOKEN vide et
# remplissez plutot ces deux valeurs (trouvees dans les identifiants API
# de votre app sur le Dev Dashboard):
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
#
SHOPIFY_API_VERSION=2024-10
# Nombre de jours a synchroniser lors du tout premier fetch
SHOPIFY_INITIAL_SYNC_DAYS=400

# --- InflatableOffice (IO) ---
# IO = plateforme "rental.software" (API6). URL de base, ex:
# https://rental.software/api6
IO_API_BASE_URL=
# Cle API (envoyee en parametre de requete "?apiKey=...", PAS en header
# Authorization/Bearer - c'est le schema documente par rental.software).
IO_API_KEY=
#
# Endpoint des ventes/contrats: le compte IO du client n'a pas de module
# "sales"/"orders" separe - c'est le module "Leads" (contrats + paiements,
# cf. permission "Lead Payments") qui joue ce role. D'ou le defaut "/leads".
IO_SALES_ENDPOINT=/leads
# Mapping des champs de la reponse IO vers nos champs internes.
# Confirme contre un extrait reel de /leads du compte client:
#   statusid: code numerique de statut (PAS encore mappe vers
#     Confirme/Soumission/Contrat-VFR - affiche brut pour l'instant, voir
#     README "Statuts et representants bruts").
#   salesrep: ID numerique du representant (affiche brut, idem).
IO_FIELD_ID=id
IO_FIELD_STATUS=statusid
IO_FIELD_AMOUNT=total
IO_FIELD_REP=salesrep
IO_FIELD_DATE=createtime
# Nombre de jours a synchroniser lors du tout premier fetch
IO_INITIAL_SYNC_DAYS=400
